{
  "name": "telegram-web-desktop",
  "version": "1.0.0",
  "description": "Windows desktop distribution for the Telegram Web Clone",
  "main": "desktop/electron/main.js",
  "author": "Saad",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "check": "npm --prefix frontend run check",
    "desktop:build-backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-backend.ps1",
    "desktop:install-electron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-electron-runtime.ps1",
    "desktop:pack": "npm run check && npm run desktop:build-backend && npm run desktop:install-electron && electron-builder --dir --publish=never",
    "desktop:dist": "npm run desktop:release -- -SkipInstall",
    "desktop:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-installer.ps1"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.saad.telegramwebdesktop",
    "productName": "Telegram Web Desktop",
    "copyright": "Copyright © 2026 Saad",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/electron/**/*",
      "desktop/assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop/dist/backend",
        "to": "backend",
        "filter": [
          "telegram_backend.exe"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "desktop/assets/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Telegram Web Desktop",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.com/telegram-web-desktop/updates/"
      }
    ]
  }
}
