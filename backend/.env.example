# Copy this file to backend/.env and adjust for your SQL Server (SSMS) instance.
# Set SQL_SERVER to the name shown in the SSMS Connect dialog.

# ---------------------------------------------------------------------------
# SQL Server
# ---------------------------------------------------------------------------
# Use the server name shown in SSMS Connect dialog, e.g. localhost\SQLEXPRESS
# or YOUR-PCNAME\SQLEXPRESS — edit for your machine before first run.
SQL_SERVER=localhost\SQLEXPRESS

# Database name (DB_NAME is preferred; SQL_DATABASE is also accepted)
DB_NAME=TelegramClone

# Local Windows/SSMS normally uses Trusted_Connection=yes.
# Hosted SQL Server/Azure SQL normally uses SQL_USER + SQL_PASSWORD instead.
# SQL_USER=
# SQL_PASSWORD=

# Optional: build connection from parts instead of SQL_SERVER
# SQL_HOST=localhost
# SQL_INSTANCE=SQLEXPRESS
# SQL_PORT=

# Optional: full ODBC override (advanced — skips SERVER candidates)
# DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=...

# Hosted databases often do not allow creating databases from the app user.
# Set true after creating DB_NAME manually in the cloud provider.
SKIP_DATABASE_CREATE=false

# ---------------------------------------------------------------------------
# Flask API
# ---------------------------------------------------------------------------
FLASK_HOST=0.0.0.0
FLASK_PORT=3000
# Many hosts set PORT automatically; it takes priority over FLASK_PORT.
# PORT=3000
FLASK_DEBUG=false

# Production full-stack mode: Flask serves frontend/index.html and static assets.
SERVE_FRONTEND=false
# FRONTEND_DIR=../frontend

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Change JWT_SECRET before any shared/production deployment
JWT_SECRET=change-me
JWT_EXPIRATION_SECONDS=604800

# ---------------------------------------------------------------------------
# CORS (optional)
# ---------------------------------------------------------------------------
# Comma-separated extra frontend origins. Default regex already allows
# localhost:5500, 127.0.0.1:5500, and LAN IPs (192.168.x.x / 10.x.x.x) on any port.
# CORS_ORIGINS=http://localhost:5500,http://192.168.1.5:5500,https://saadh472.github.io

# ---------------------------------------------------------------------------
# Pagination / cache
# ---------------------------------------------------------------------------
MESSAGES_DEFAULT_LIMIT=50
MESSAGES_MAX_LIMIT=500
CHATS_LIST_LIMIT=200
CHATS_CACHE_TTL=15
USERS_CACHE_TTL=30
